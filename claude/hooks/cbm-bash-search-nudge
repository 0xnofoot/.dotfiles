#!/bin/bash
# PreToolUse(Bash) nudge：主 agent 找代码走 Bash（rg/fd/grep/find），
# 不触发 cbm-code-discovery-gate（那个只挂 Grep|Glob|Find 工具名）。
# 本 hook 在 Bash 命令含搜索类命令时注入一句提醒，**从不阻断**，
# 任何异常静默 exit 0。判断权留给模型：结构性查询才该走 codebase-memory。
set -e

command -v jq >/dev/null 2>&1 || exit 0

payload="$(cat)"
cmd="$(printf '%s' "$payload" | jq -r '.tool_input.command // empty' 2>/dev/null)" || exit 0
[ -n "$cmd" ] || exit 0

# 仅当搜索命令处于「命令位置」（行首，或 ; & | ( 之后，允许 command/sudo/time
# 等前缀）时才提醒，避免 commit message、echo 参数、含 find 的文件名等误触发。
# 用 bash 内建正则，避免依赖被 shadow 的 grep。
re='(^|[;&|(]|'$'\n'')[[:space:]]*((command|sudo|time|nice|nohup|xargs)[[:space:]]+)*(rg|grep|egrep|fgrep|ugrep|ug|find|fd|bfs|ag|ack)([[:space:]]|$)'
[[ "$cmd" =~ $re ]] || exit 0

jq -cn '{
  hookSpecificOutput: {
    hookEventName: "PreToolUse",
    additionalContext: "提醒：结构性代码查询（找定义/调用者/调用链/影响分析/死代码）应先用 codebase-memory MCP（mcp__codebase-memory-mcp__search_graph / trace_path / get_code_snippet / query_graph）。当前 Bash 搜索仅适合纯文本串/文件名检索；若本次是结构性查询，请改走 MCP。"
  }
}'
exit 0
