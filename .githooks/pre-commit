#!/bin/bash
#
# pre-commit hook:
#   1. 检查 VSCode/Cursor 扩展列表是否同步
#   2. 若 vscode/defaults/ 有变更，检查 keybindings.json 禁用列表是否已更新
#   检查不通过时交互式询问是否自动修复
#

DOTFILES_DIR="$(git rev-parse --show-toplevel)"
SYNC_SCRIPT="$DOTFILES_DIR/vscode/scripts/sync-extensions.sh"
GENERATE_SCRIPT="$DOTFILES_DIR/vscode/scripts/generate-disabled-defaults.py"

warn() { printf "\033[1;33m==>\033[0m \033[1m%s\033[0m\n" "$1"; }
ok()   { printf "\033[1;32m==>\033[0m \033[1m%s\033[0m\n" "$1"; }

ask_fix() {
  # 非交互环境（CI/IDE 无 TTY）默认不修复
  [[ ! -t 0 ]] && ! [[ -e /dev/tty ]] && return 1
  printf "\033[1;34m==>\033[0m \033[1m是否自动修复并加入本次提交？(y/N) \033[0m"
  read -r answer < /dev/tty
  [[ "$answer" == [yY] ]]
}

# ── 1. 扩展列表同步 ──
if [[ -f "$SYNC_SCRIPT" ]]; then
  if ! bash "$SYNC_SCRIPT" --check; then
    if ask_fix; then
      bash "$SYNC_SCRIPT" <<< "y"
      git add "$DOTFILES_DIR/vscode/extensions.txt" \
              "$DOTFILES_DIR/vscode/extensions-code.txt" \
              "$DOTFILES_DIR/vscode/extensions-cursor.txt"
      ok "扩展列表已同步并暂存"
    else
      exit 1
    fi
  fi
fi

# ── 2. 默认快捷键禁用列表 ──
if [[ -f "$GENERATE_SCRIPT" ]] && git diff --cached --name-only | grep -q '^vscode/defaults/'; then
  if ! python3 "$GENERATE_SCRIPT" --check; then
    if ask_fix; then
      python3 "$GENERATE_SCRIPT"
      git add "$DOTFILES_DIR/vscode/keybindings.json"
      ok "禁用列表已更新并暂存"
    else
      exit 1
    fi
  fi
fi
