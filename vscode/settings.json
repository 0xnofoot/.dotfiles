{
  //========== AI 助手 ==========//
  // --- Cursor ---
  "cursor.cpp.disabledLanguages": ["plaintext", "markdown", "scminput"],
  "cursor.composer.shouldAutoAcceptDiffs": false,
  "cursorpyright.analysis.typeCheckingMode": "standard",
  "cursorpyright.analysis.inlayHints.callArgumentNames": true,
  "cursorpyright.analysis.inlayHints.functionReturnTypes": true,
  "cursorpyright.analysis.inlayHints.variableTypes": true,
  // --- GitHub Copilot ---
  "github.copilot.enable": {
    "*": false
  },
  // --- Claude Code ---
  "claudeCode.preferredLocation": "panel",
  // --- Chat ---
  "chat.viewSessions.orientation": "stacked",
  //========== 通用设置 ==========//
  "terminal.external.osxExec": "kitty.app",
  "files.autoGuessEncoding": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  //========== 外观与布局 ==========//
  "workbench.colorTheme": "Syntax Material Dark",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.activityBar.orientation": "vertical",
  "workbench.layoutControl.enabled": false,
  "window.restoreWindows": "all",
  //========== 编辑器 ==========//
  "editor.fontFamily": "FiraMono Nerd Font Mono, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 13,
  "editor.cursorBlinking": "smooth",
  "editor.mouseWheelZoom": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": false,
  "editor.formatOnType": false,
  "editor.guides.bracketPairs": false,
  "editor.cursorSurroundingLines": 10,
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.find.addExtraSpaceOnTop": false,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "trailing",
  "editor.smoothScrolling": true,
  "editor.wordWrap": "on",
  // editor.lineNumbers 由 vim.smartRelativeLine 自动控制
  "editor.stickyScroll.enabled": false,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.suggestSelection": "recentlyUsed",
  //========== 调试 ==========//
  "debug.toolBarLocation": "floating",
  //========== 版本控制 ==========//
  "git.openRepositoryInParentFolders": "never",
  "git.blame.editorDecoration.enabled": false,
  "git.blame.statusBarItem.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.views.commitDetails.files.layout": "tree",
  //========== 扩展工具 ==========//
  // --- IndentRainbow ---
  "indentRainbow.indicatorStyle": "light",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "indentRainbow.colors": [
    "rgba(255,255,64,0.3)",
    "rgba(127,255,127,0.3)",
    "rgba(255,127,255,0.3)",
    "rgba(79,236,236,0.3)"
  ],
  // --- Clipboard Manager ---
  "clipboard-manager.snippet.enabled": false,
  // --- Notebook ---
  "notebook.output.wordWrap": true,
  "notebook.lineNumbers": "on",
  "notebook.output.textLineLimit": 50,
  // --- LeetCode ---
  "leetcode.endpoint": "leetcode-cn",
  "leetcode.hint.commandShortcut": false,
  "leetcode.hint.configWebviewMarkdown": false,
  "leetcode.workspaceFolder": "/Users/toofonwang/.leetcode",
  // --- ESLint ---
  "eslint.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  // --- LLDB ---
  "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/LLDB",
  //========== 语言设置 ==========//
  //---------- Python ----------//
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 2,
    "editor.inlayHints.enabled": "offUnlessPressed"
  },
  "python.languageServer": "Pylance",
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.pytestParameters": false,
  "python.analysis.inlayHints.callArgumentNames": "off",
  "python.analysis.inlayHints.functionReturnTypes": false,
  "python.analysis.inlayHints.variableTypes": false,
  //---------- Go ----------//
  "[go]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never" // 关键设置
    },
    "editor.formatOnSave": false // 双重保障
  },
  "go.toolsManagement.autoUpdate": false, // 禁止自动更新工具
  //---------- Dart / Flutter ----------//
  "dart.lineLength": 200,
  "dart.warnWhenEditingFilesOutsideWorkspace": false,
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  "dart.openDevTools": "flutter",
  "dart.devToolsLocation": {
    "default": "active"
  },
  //---------- Kotlin / Java ----------//
  "ktfmtter.ktfmtVersion": "0.53",
  "ktfmtter.style": "kotlinlang",
  "ktfmtter.java-runtime": "JavaSE-21",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-17",
      "path": "/Users/toofonwang/Library/Java/JavaVirtualMachines/ms-17.0.17/Contents/Home",
      "default": true
    },
    {
      "name": "JavaSE-21",
      "path": "/Users/toofonwang/Library/Java/JavaVirtualMachines/ms-21.0.9/Contents/Home"
    }
  ],
  "[kotlin]": {
    // "editor.defaultFormatter": "shape-app.ktfmtter",
    "editor.defaultFormatter": "JetBrains.kotlin",
    "editor.inlayHints.enabled": "offUnlessPressed"
  },
  //---------- Swift ----------//
  "[swift]": {
    "editor.defaultFormatter": "swiftlang.swift-vscode",
    "editor.inlayHints.enabled": "offUnlessPressed"
  },
  "swift.sourcekit-lsp.backgroundIndexing": "auto",
  //---------- Objective-C ----------//
  "[objective-c]": {
    "editor.inlayHints.enabled": "offUnlessPressed"
  },
  //---------- Web (HTML / CSS / JS / TS) ----------//
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  //---------- JSON / YAML ----------//
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  //---------- Markdown ----------//
  "[markdown]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  //---------- Docker ----------//
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  //========== 远程开发 ==========//
  "remote.SSH.remotePlatform": {
    "dev-host-toofonwang": "linux"
  },
  //========== Vim ==========//
  // autoSwitchInputMethod 仅在 macOS 生效（/opt/homebrew/bin/im-select）。
  // settings.json 不支持按 OS 条件分段，Linux 上 VSCode 会在模式切换时
  // 尝试调用不存在的二进制，扩展静默降级，不影响编辑器正常使用。
  "vim.autoSwitchInputMethod.enable": true,
  "vim.autoSwitchInputMethod.defaultIM": "com.apple.keylayout.ABC",
  "vim.autoSwitchInputMethod.obtainIMCmd": "/opt/homebrew/bin/im-select",
  "vim.autoSwitchInputMethod.switchIMCmd": "/opt/homebrew/bin/im-select {im}",
  "vim.leader": "<space>",
  "vim.easymotion": true,
  "vim.searchHighlightColor": "rgba(150, 150, 150, 0.4)",
  "vim.useSystemClipboard": true,
  "vim.enableNeovim": false,
  "vim.smartRelativeLine": true,
  "vim.incsearch": true,
  "vim.hlsearch": true,
  "vim.useCtrlKeys": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    // 光标移动
    {
      "before": ["J"],
      "after": ["5", "j"]
    },
    {
      "before": ["K"],
      "after": ["5", "k"]
    },
    {
      "before": ["<C-j>"],
      "after": ["<C-d>"]
    },
    {
      "before": ["<C-k>"],
      "after": ["<C-u>"]
    },
    {
      "before": ["H"],
      "after": ["3", "h"]
    },
    {
      "before": ["L"],
      "after": ["3", "l"]
    },
    {
      "before": ["W"],
      "after": ["3", "w"]
    },
    {
      "before": ["E"],
      "after": ["3", "e"]
    },
    {
      "before": ["B"],
      "after": ["3", "b"]
    },
    {
      "before": ["<C-o>"],
      "commands": ["workbench.action.navigateBack"]
    },
    {
      "before": ["<C-i>"],
      "commands": ["workbench.action.navigateForward"]
    },
    // 窗口与分组
    {
      "before": ["z", "h"],
      "commands": ["workbench.action.splitEditorLeft"]
    },
    {
      "before": ["z", "j"],
      "commands": ["workbench.action.splitEditorDown"]
    },
    {
      "before": ["z", "k"],
      "commands": ["workbench.action.splitEditorUp"]
    },
    {
      "before": ["z", "l"],
      "commands": ["workbench.action.splitEditorRight"]
    },
    {
      "before": ["z", "q"],
      "commands": ["workbench.action.closeGroup"]
    },
    {
      "before": ["z", "Q"],
      "commands": ["workbench.action.closeEditorsInOtherGroups"]
    },
    {
      "before": ["leader", "k"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["leader", "j"],
      "commands": ["workbench.action.focusBelowGroup"]
    },
    {
      "before": ["leader", "h"],
      "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["leader", "l"],
      "commands": ["workbench.action.focusRightGroup"]
    },
    {
      "before": ["<up>"],
      "commands": ["workbench.action.increaseViewSize"]
    },
    {
      "before": ["<down>"],
      "commands": ["workbench.action.decreaseViewSize"]
    },
    {
      "before": ["<left>"],
      "commands": ["workbench.action.decreaseViewWidth"]
    },
    {
      "before": ["<right>"],
      "commands": ["workbench.action.increaseViewWidth"]
    },
    {
      "before": ["leader", "q", "q"],
      "commands": ["workbench.action.closeOtherEditors"]
    },
    {
      "before": ["leader", "q", "l"],
      "commands": ["workbench.action.closeEditorsToTheRight"]
    },
    {
      "before": ["leader", "q", "h"],
      "commands": ["workbench.action.closeEditorsToTheLeft"]
    },
    {
      "before": ["t", "t"],
      "commands": ["workbench.action.files.newUntitledFile"]
    },
    // 搜索与导航
    {
      "before": ["leader", "f"],
      "commands": ["workbench.view.search.focus"]
    },
    {
      "before": ["leader", "e", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["leader", "e", "g"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["leader", "e", "o"],
      "commands": ["workbench.action.openRecent"]
    },
    {
      "before": ["leader", "e", "b"],
      "commands": ["workbench.action.showAllEditors"]
    },
    {
      "before": ["leader", "<enter>"],
      "commands": [":nohl"]
    },
    // 文本编辑
    {
      "before": [";"],
      "after": [":"]
    },
    {
      "before": ["S"],
      "commands": [":w"]
    },
    {
      "before": ["Q"],
      "commands": [":q"]
    },
    {
      "before": ["`"],
      "after": ["~"]
    },
    {
      "before": ["'"],
      "after": ["%"]
    },
    {
      "before": [","],
      "after": ["0"]
    },
    {
      "before": ["."],
      "after": ["$"]
    },
    {
      "before": ["v", "'"],
      "after": ["v", "%"]
    },
    {
      "before": ["d", "'"],
      "after": ["d", "%"]
    },
    {
      "before": ["c", "'"],
      "after": ["c", "%"]
    },
    {
      "before": ["v", ","],
      "after": ["v", "0"]
    },
    {
      "before": ["d", ","],
      "after": ["d", "0"]
    },
    {
      "before": ["c", ","],
      "after": ["c", "0"]
    },
    {
      "before": ["v", "."],
      "after": ["v", "$", "h"]
    },
    {
      "before": ["d", "."],
      "after": ["v", "$", "h", "d"]
    },
    {
      "before": ["c", "."],
      "after": ["c", "$"]
    },
    {
      "before": ["Y"],
      "after": ["y", "$"]
    },
    {
      "before": ["U"],
      "after": ["<C-r>"]
    },
    {
      "before": ["<enter>"],
      "commands": ["editor.action.smartSelect.expand"]
    },
    {
      "before": ["<backspace>"],
      "commands": ["editor.action.smartSelect.shrink"]
    },
    // 代码操作
    {
      "before": ["leader", "g", "f"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["g", "j"],
      "commands": ["editor.action.revealDeclaration"]
    },
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"]
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["g", "o"],
      "commands": ["editor.action.goToTypeDefinition"]
    },
    {
      "before": ["g", "h"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["g", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["g", "r"],
      "commands": ["references-view.find"]
    },
    {
      "before": ["g", "R"],
      "commands": ["editor.action.rename"]
    },
    {
      "before": ["g", "T"],
      "commands": ["workbench.actions.view.problems"]
    },
    // 禁用
    {
      "before": ["g", "f"],
      "commands": [""]
    },
    {
      "before": ["q"],
      "commands": [""]
    },
    // 侧边栏面板
    {
      "before": ["leader", "w"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["leader", "v"],
      "commands": ["workbench.view.scm"]
    },
    {
      "before": ["leader", "d"],
      "commands": ["workbench.view.debug"]
    },
    {
      "before": ["leader", "r"],
      "commands": ["workbench.view.extension.references-view"]
    },
    {
      "before": ["leader", "o"],
      "commands": ["outline.focus"]
    },
    {
      "before": ["leader", "m"],
      "commands": ["bookmarksExplorer.focus"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    // 光标移动
    {
      "before": ["J"],
      "after": ["5", "j"]
    },
    {
      "before": ["K"],
      "after": ["5", "k"]
    },
    {
      "before": ["<C-j>"],
      "after": ["<C-d>"]
    },
    {
      "before": ["<C-k>"],
      "after": ["<C-u>"]
    },
    {
      "before": ["H"],
      "after": ["3", "h"]
    },
    {
      "before": ["L"],
      "after": ["3", "l"]
    },
    {
      "before": ["W"],
      "after": ["3", "w"]
    },
    {
      "before": ["E"],
      "after": ["3", "e"]
    },
    {
      "before": ["B"],
      "after": ["3", "b"]
    },
    // 文本编辑
    {
      "before": ["<enter>"],
      "commands": ["editor.action.smartSelect.expand"]
    },
    {
      "before": ["<backspace>"],
      "commands": ["editor.action.smartSelect.shrink"]
    },
    // 代码操作
    {
      "before": ["leader", "g", "f"],
      "commands": ["editor.action.formatSelection"]
    },
    // 禁用
    {
      "before": ["g", "f"],
      "commands": [""]
    },
    {
      "before": ["u"],
      "commands": [""]
    },
    {
      "before": ["U"],
      "commands": [""]
    },
    {
      "before": ["leader", "u"],
      "after": ["u"]
    },
    {
      "before": ["leader", "U"],
      "after": ["U"]
    }
  ]
  //========== End ==========//
}
